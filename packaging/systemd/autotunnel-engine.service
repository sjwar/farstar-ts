[Unit]
Description=AutoTunnel-X orchestration engine
After=network-online.target docker.service
Wants=network-online.target docker.service

[Service]
Type=simple
User=root
Group=root
Environment=AUTOTUNNEL_CONFIG=/etc/autotunnel-x/config.yaml
ExecStart=/opt/autotunnel-x/venv/bin/autotunnelctl engine --config /etc/autotunnel-x/config.yaml
Restart=always
RestartSec=5
KillSignal=SIGTERM
TimeoutStopSec=25
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
